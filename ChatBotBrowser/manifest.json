{
  "manifest_version": 3,
  "name": "AI Site Assistant",
  "version": "1.0",
  "description": "Chat with any website",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}